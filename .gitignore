# ======================================
# 1. 本地环境与敏感配置
# ======================================
# 虚拟环境目录由本地生成，不提交到仓库
.venv/
venv/
env/

# 环境变量文件通常包含密钥、账号、密码等敏感信息
.env
.env.*
!.env.example

# ======================================
# 2. Python 缓存与构建产物
# ======================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

build/
dist/
*.egg-info/
*.egg

# 测试、覆盖率和类型检查缓存
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ======================================
# 3. 日志、临时文件与运行产物
# ======================================
logs/
*.log
*.tmp
*.temp

# 大体积模型、数据和压缩包不直接提交到 Git
*.bin
*.pth
*.pt
*.safetensors
*.csv
*.zip

# ======================================
# 4. 编辑器与系统文件
# ======================================
.vscode/
.idea/
*.swp
*.swo
*~

.DS_Store
Thumbs.db
